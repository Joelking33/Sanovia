# ============================================================
# SANOovIA - Configuration de l'environnement
# ============================================================

# Base de données
# SQLite (développement) :
DATABASE_URL=file:/home/z/my-project/db/custom.db
# PostgreSQL (production) :
# DATABASE_URL=postgresql://user:password@localhost:5432/sanoovia

# JWT
JWT_SECRET=sanoovia-jwt-secret-change-in-production-2024
JWT_EXPIRES_IN=7d

# Google OAuth (à configurer dans Google Cloud Console)
GOOGLE_CLIENT_ID=votre-google-client-id.apps.googleusercontent.com

# Langues supportées : fr, ba (baoulé), dy (dioula), bq (bété)
DEFAULT_LANGUAGE=fr
